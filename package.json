{
  "name": "kyc-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/kyc-agent.ts",
    "server": "tsx src/server.ts",
    "dev": "concurrently -n api,web -c blue,magenta \"tsx src/server.ts\" \"vite\"",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit",
    "test:id-extract": "tsx scripts/test-id-extract.ts",
    "test:face-match": "tsx scripts/test-face-match.ts"
  },
  "dependencies": {
    "@openai/agents": "^0.3.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "openai": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.6"
  },
  "engines": {
    "node": ">=22"
  }
}
